# Easy Sanity runtime configuration
# Note: this project reads real environment variables.
# If you use Codex MCP config, copy these values into the server's "env" block.
# If you run locally in a shell, export them before starting the MCP server.

# Run browser sessions headless by default unless browser_start overrides it.
BROWSER_HEADLESS_DEFAULT=true

# Default Playwright timeout in milliseconds.
BROWSER_DEFAULT_TIMEOUT_MS=45000

# Browser runtime backend.
# Supported values today: playwright, browser-harness
BROWSER_BACKEND_DEFAULT=playwright

# Allow selecting browser-harness mode.
# The harness backend is detected and validated now; runtime execution will be added next.
BROWSER_HARNESS_ENABLED=false

# Optional override for the browser-harness command on PATH.
BROWSER_HARNESS_COMMAND=browser-harness

# Optional reference URL for setup/error messages.
BROWSER_HARNESS_REPO=https://github.com/browser-use/browser-harness

# Artifact directories.
# Relative paths resolve from the project root.
BROWSER_REPORTS_DIR=artifacts/reports
BROWSER_SCREENSHOTS_DIR=artifacts/screenshots
BROWSER_DOWNLOADS_DIR=artifacts/downloads

# Persistent repo-understanding memory directory.
APP_MEMORY_DIR=data/app_memory
